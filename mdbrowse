#!/usr/bin/env python3
"""
mdbrowse — open a file, folder, GitHub repo, or GitHub PR in the file-browser app.

Usage:
  mdbrowse                       open the app, no folder loaded
  mdbrowse PATH                  open file or folder (PATH may be relative)
  mdbrowse owner/repo            shallow-clone a GitHub repo and serve it
  mdbrowse https://github.com/owner/repo
  mdbrowse owner/repo#123        check out PR #123 and serve only its changed files
  mdbrowse https://github.com/owner/repo/pull/123
  mdbrowse PATH --all            show every file (default: only .md / .markdown / .mdx)
  mdbrowse PATH -a               shorthand for --all

Behaviour:
  * No PATH      — opens the app idle. The "Markdown only" toggle reflects the
                   --all flag (on by default).
  * PATH is file — opens the file directly in Chrome (Chrome handles HTML /
                   PDF / images natively; everything else is shown raw).
  * PATH is dir  — spins up a localhost HTTP server rooted at PATH, opens the
                   app pointed at it, and the app fetches files over HTTP.
                   Ctrl+C to stop the server.
  * GitHub spec  — `git clone --depth 1` into a temp dir, then serve as above.
                   Temp dir is removed on Ctrl+C.

Skip list (folders never indexed):
  .git  node_modules  __pycache__  .DS_Store  .next  dist  build  .venv  venv
"""
from __future__ import annotations
import argparse
import atexit
import functools
import http.server
import json
import os
import re
import shutil
import socket
import subprocess
import sys
import tempfile
import threading
from pathlib import Path
from urllib.parse import parse_qs, urlsplit

SCRIPT_DIR = Path(__file__).resolve().parent
APP_HTML = SCRIPT_DIR / "index.html"

SKIP_DIRS = {".git", "node_modules", "__pycache__", ".DS_Store",
             ".next", "dist", "build", ".venv", "venv"}

MD_EXTS = (".md", ".markdown", ".mdx")
SEARCH_INDEX_SIZE_LIMIT = 1 * 1024 * 1024  # 1 MB per file
SEARCH_MAX_RESULTS = 50
SEARCH_SNIPPETS_PER_FILE = 3


def parse_args() -> argparse.Namespace:
    ap = argparse.ArgumentParser(
        prog="mdbrowse",
        description="Open a file, folder, or GitHub repo in the file-browser app.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            "Examples:\n"
            "  mdbrowse                          # idle app, md-only on\n"
            "  mdbrowse vTax/containerize-executor\n"
            "  mdbrowse vTax -a                  # show all files, not just .md\n"
            "  mdbrowse vTax/README.md           # render a single file in Chrome\n"
            "  mdbrowse agarwal-manav/mdbrowse   # clone + serve a GitHub repo\n"
        ),
    )
    ap.add_argument("path", nargs="?", help="file, folder, or GitHub spec")
    ap.add_argument("-a", "--all", action="store_true",
                    help="show every file (default: markdown only)")
    ap.add_argument("--update", action="store_true",
                    help="git-pull the install directory and re-symlink the CLI")
    return ap.parse_args()


def open_chrome(url: str) -> None:
    """Open a URL in Chrome; fall back to default browser if Chrome is absent."""
    chrome = "/Applications/Google Chrome.app"
    if Path(chrome).exists():
        subprocess.run(["open", "-a", "Google Chrome", url], check=False)
    else:
        subprocess.run(["open", url], check=False)


# ─── Self-update helpers ───────────────────────────────────────────────────

def _install_dir_is_git() -> bool:
    return (SCRIPT_DIR / ".git").exists()


def maybe_check_for_updates() -> None:
    """
    Background-fetch origin and print a one-line notice if the install dir
    is behind. No-op if not a git checkout (e.g. user copied the script).
    """
    if not _install_dir_is_git():
        return

    def run() -> None:
        try:
            subprocess.run(
                ["git", "-C", str(SCRIPT_DIR), "fetch", "--quiet", "origin"],
                timeout=10, capture_output=True, check=False,
            )
            out = subprocess.check_output(
                ["git", "-C", str(SCRIPT_DIR), "rev-list", "--count", "HEAD..@{u}"],
                text=True, stderr=subprocess.DEVNULL, timeout=5,
            ).strip()
            n = int(out or "0")
            if n > 0:
                print(f"mdbrowse: update available ({n} commit"
                      f"{'' if n == 1 else 's'} behind) — run `mdbrowse --update`")
        except Exception:
            # Network down, no upstream, detached HEAD — silently ignore.
            pass

    threading.Thread(target=run, daemon=True).start()


def self_update() -> int:
    """`mdbrowse --update`: pull and re-run install.sh to refresh the symlink."""
    if not _install_dir_is_git():
        print(f"mdbrowse: install dir {SCRIPT_DIR} is not a git checkout — "
              "nothing to update.", file=sys.stderr)
        return 1
    print(f"mdbrowse: pulling latest in {SCRIPT_DIR}")
    pull = subprocess.run(
        ["git", "-C", str(SCRIPT_DIR), "pull", "--ff-only"],
    )
    if pull.returncode != 0:
        print("mdbrowse: git pull failed — resolve manually and retry",
              file=sys.stderr)
        return pull.returncode
    install_sh = SCRIPT_DIR / "install.sh"
    if install_sh.exists():
        subprocess.run(["bash", str(install_sh)])
    print("mdbrowse: updated.")
    return 0


def free_port(start: int = 8765) -> int:
    """Find an unused port starting from `start`."""
    for p in range(start, start + 200):
        with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
            try:
                s.bind(("127.0.0.1", p))
                return p
            except OSError:
                continue
    raise RuntimeError("could not find a free port in 200 attempts")


# ─── GitHub repo support ───────────────────────────────────────────────────

# owner/repo — letters, digits, dots, dashes, underscores.
_GH_SHORT = re.compile(r"^[\w.-]+/[\w.-]+$")


def github_clone_url(spec: str) -> str | None:
    """Return a clonable URL if `spec` looks like a GitHub repo, else None."""
    if _GH_SHORT.match(spec):
        return f"https://github.com/{spec}.git"
    if spec.startswith("git@github.com:"):
        return spec
    if spec.startswith(("http://", "https://")):
        host = urlsplit(spec).netloc.lower()
        if host in ("github.com", "www.github.com"):
            return spec if spec.endswith(".git") else spec.rstrip("/") + ".git"
    return None


def clone_github(url: str) -> Path:
    """Shallow-clone `url` into a temp dir and register cleanup. Returns the dir."""
    tmp = Path(tempfile.mkdtemp(prefix="mdbrowse-"))
    atexit.register(lambda: shutil.rmtree(tmp, ignore_errors=True))
    print(f"mdbrowse: cloning {url}")
    try:
        subprocess.run(
            ["git", "clone", "--depth", "1", url, str(tmp)],
            check=True,
        )
    except subprocess.CalledProcessError as e:
        shutil.rmtree(tmp, ignore_errors=True)
        raise SystemExit(f"mdbrowse: git clone failed ({e.returncode})")
    return tmp


# ─── GitHub PR support ─────────────────────────────────────────────────────

# owner/repo#123
_GH_PR_SHORT = re.compile(r"^([\w.-]+)/([\w.-]+)#(\d+)$")
# https://github.com/owner/repo/pull/123 (trailing slash or /files etc. ignored)
_GH_PR_URL = re.compile(r"^https?://github\.com/([\w.-]+)/([\w.-]+)/pull/(\d+)(?:[/?#].*)?$")


def github_pr_spec(spec: str) -> tuple[str, str, int] | None:
    """Return (owner, repo, number) if `spec` is a GitHub PR reference, else None."""
    m = _GH_PR_SHORT.match(spec) or _GH_PR_URL.match(spec)
    if not m:
        return None
    return m.group(1), m.group(2), int(m.group(3))


def _ensure_gh() -> None:
    if shutil.which("gh") is None:
        raise SystemExit(
            "mdbrowse: PR mode needs the GitHub CLI. Install it: brew install gh"
        )


def fetch_pr(owner: str, repo: str, num: int) -> tuple[Path, list[str], dict, dict[str, list[dict]]]:
    """
    Clone owner/repo, check out PR #num via `gh`, and return:
        (tmpdir, changed_file_paths, github_context, review_comments_by_path)
    The PR summary is written to `<tmpdir>/_PR.md`. Cleanup is registered with atexit.
    """
    _ensure_gh()
    pr_ref = f"{owner}/{repo}#{num}"

    print(f"mdbrowse: fetching metadata for {pr_ref}")
    fields = (
        "title,body,author,state,url,labels,baseRefName,headRefName,headRefOid,"
        "additions,deletions,createdAt,mergedAt,comments,reviews,files"
    )
    try:
        raw = subprocess.check_output(
            ["gh", "pr", "view", str(num), "--repo", f"{owner}/{repo}",
             "--json", fields],
            text=True,
        )
    except subprocess.CalledProcessError as e:
        raise SystemExit(f"mdbrowse: gh pr view failed ({e.returncode})")
    meta = json.loads(raw)

    tmp = Path(tempfile.mkdtemp(prefix="mdbrowse-pr-"))
    atexit.register(lambda: shutil.rmtree(tmp, ignore_errors=True))

    print(f"mdbrowse: cloning {owner}/{repo}")
    try:
        subprocess.run(
            ["git", "clone", "--quiet", f"https://github.com/{owner}/{repo}.git", str(tmp)],
            check=True,
        )
        print(f"mdbrowse: checking out PR #{num}")
        subprocess.run(
            ["gh", "pr", "checkout", str(num)],
            cwd=str(tmp), check=True,
        )
    except subprocess.CalledProcessError as e:
        shutil.rmtree(tmp, ignore_errors=True)
        raise SystemExit(f"mdbrowse: clone/checkout failed ({e.returncode})")

    # Files that still exist after checkout (excludes deleted files).
    changed: list[str] = []
    for f in meta.get("files", []) or []:
        path = f.get("path")
        if path and (tmp / path).exists():
            changed.append(path)

    # Synthesised summary at the root of the served tree.
    (tmp / "_PR.md").write_text(render_pr_markdown(meta, owner, repo, num), encoding="utf-8")

    # Line-level review comments (separate API from gh pr view's "comments").
    review_comments_by_path = fetch_pr_line_comments(owner, repo, num)
    # Set of lines we're allowed to comment on per file (must be in the diff).
    commentable_by_path = fetch_pr_diff_lines(owner, repo, num)

    head_ref = meta.get("headRefOid") or meta.get("headRefName") or "HEAD"
    github_context = {
        "owner": owner,
        "repo": repo,
        "prUrl": meta.get("url"),
        "prNumber": num,
        "headRef": head_ref,
        "commentableLines": commentable_by_path,
        # Per-file blob URL: append "/<relpath>" to construct each file link.
        "baseBlobUrl": f"https://github.com/{owner}/{repo}/blob/{head_ref}",
    }
    return tmp, changed, github_context, review_comments_by_path


_HUNK_RE = re.compile(r"^@@ -\d+(?:,\d+)? \+(\d+)(?:,(\d+))? @@")


def parse_diff_commentable_lines(diff_text: str) -> dict[str, list[int]]:
    """
    For each file in `diff_text`, return the set of RIGHT-side line numbers
    covered by hunks (i.e. the lines GitHub will accept review comments on).
    Returned as sorted lists for JSON serialisation.
    """
    out: dict[str, set[int]] = {}
    cur_path: str | None = None
    for line in diff_text.splitlines():
        if line.startswith("+++ b/"):
            cur_path = line[6:]
            out.setdefault(cur_path, set())
        elif line.startswith("+++ /dev/null"):
            cur_path = None
        elif cur_path and line.startswith("@@"):
            m = _HUNK_RE.match(line)
            if m:
                start = int(m.group(1))
                length = int(m.group(2)) if m.group(2) else 1
                out[cur_path].update(range(start, start + length))
    return {p: sorted(s) for p, s in out.items() if s}


def fetch_pr_diff_lines(owner: str, repo: str, num: int) -> dict[str, list[int]]:
    """Fetch the PR's unified diff and parse out commentable RIGHT-side line numbers."""
    try:
        diff = subprocess.check_output(
            ["gh", "pr", "diff", str(num), "--repo", f"{owner}/{repo}"],
            text=True,
        )
    except subprocess.CalledProcessError:
        return {}
    return parse_diff_commentable_lines(diff)


def fetch_pr_line_comments(owner: str, repo: str, num: int) -> dict[str, list[dict]]:
    """Pull PR review comments (the inline, line-anchored kind) grouped by file path."""
    out: dict[str, list[dict]] = {}
    try:
        raw = subprocess.check_output(
            ["gh", "api", "--paginate",
             f"repos/{owner}/{repo}/pulls/{num}/comments",
             "--jq",
             ('[.[] | {path, line, original_line, body, '
              'user: .user.login, created_at, html_url, in_reply_to_id, id}]')],
            text=True,
        )
    except subprocess.CalledProcessError:
        return out
    # `gh api --paginate --jq` emits one JSON array per page; concatenate them.
    items: list[dict] = []
    for chunk in raw.strip().splitlines():
        if not chunk.strip():
            continue
        try:
            items.extend(json.loads(chunk))
        except json.JSONDecodeError:
            continue
    for c in items:
        path = c.get("path")
        if not path:
            continue
        out.setdefault(path, []).append({
            "line": c.get("line") or c.get("original_line"),
            "body": c.get("body") or "",
            "user": c.get("user") or "?",
            "createdAt": c.get("created_at") or "",
            "htmlUrl": c.get("html_url") or "",
        })
    for v in out.values():
        v.sort(key=lambda c: ((c.get("line") or 0), c.get("createdAt") or ""))
    return out


def detect_repo_github_context(repo_dir: Path) -> dict | None:
    """If `repo_dir` is a git checkout of a github.com repo, return a context dict."""
    try:
        url = subprocess.check_output(
            ["git", "-C", str(repo_dir), "remote", "get-url", "origin"],
            text=True, stderr=subprocess.DEVNULL,
        ).strip()
        branch = subprocess.check_output(
            ["git", "-C", str(repo_dir), "rev-parse", "--abbrev-ref", "HEAD"],
            text=True, stderr=subprocess.DEVNULL,
        ).strip() or "HEAD"
    except subprocess.CalledProcessError:
        return None
    m = re.match(r"^(?:https?://github\.com/|git@github\.com:)([\w.-]+)/([\w.-]+?)(?:\.git)?/?$", url)
    if not m:
        return None
    owner, repo = m.group(1), m.group(2)
    return {
        "owner": owner,
        "repo": repo,
        "headRef": branch,
        "baseBlobUrl": f"https://github.com/{owner}/{repo}/blob/{branch}",
    }


def render_pr_markdown(meta: dict, owner: str, repo: str, num: int) -> str:
    """Render PR metadata, description, comments, and reviews as a single markdown doc."""
    title = meta.get("title") or "(no title)"
    state = meta.get("state") or "?"
    author = (meta.get("author") or {}).get("login") or "?"
    labels = ", ".join(l.get("name", "") for l in (meta.get("labels") or [])) or "—"
    base = meta.get("baseRefName") or "?"
    head = meta.get("headRefName") or "?"
    url = meta.get("url") or f"https://github.com/{owner}/{repo}/pull/{num}"
    adds = meta.get("additions", 0)
    dels = meta.get("deletions", 0)
    created = meta.get("createdAt") or ""
    merged = meta.get("mergedAt") or ""

    out: list[str] = []
    out.append(f"# PR #{num}: {title}\n")
    out.append(f"[{url}]({url})\n")
    out.append("")
    out.append("| | |")
    out.append("|---|---|")
    out.append(f"| Author | `@{author}` |")
    out.append(f"| State | **{state}** |")
    out.append(f"| Branch | `{head}` → `{base}` |")
    out.append(f"| Diff | +{adds} / −{dels} |")
    out.append(f"| Labels | {labels} |")
    if created:
        out.append(f"| Created | {created} |")
    if merged:
        out.append(f"| Merged | {merged} |")
    out.append("")

    body = (meta.get("body") or "").strip()
    out.append("## Description\n")
    out.append(body if body else "_(no description)_")
    out.append("")

    files = meta.get("files") or []
    out.append(f"## Changed files ({len(files)})\n")
    for f in files:
        path = f.get("path", "")
        a = f.get("additions", 0)
        d = f.get("deletions", 0)
        out.append(f"- `{path}` — +{a}/−{d}")
    out.append("")

    reviews = [r for r in (meta.get("reviews") or []) if (r.get("body") or "").strip() or r.get("state")]
    out.append(f"## Reviews ({len(reviews)})\n")
    if not reviews:
        out.append("_(none)_\n")
    for r in reviews:
        rauthor = (r.get("author") or {}).get("login") or "?"
        rstate = r.get("state") or ""
        when = r.get("submittedAt") or ""
        out.append(f"### `@{rauthor}` — **{rstate}** · {when}\n")
        rbody = (r.get("body") or "").strip()
        out.append(rbody if rbody else "_(no body)_")
        out.append("")

    comments = meta.get("comments") or []
    out.append(f"## Issue comments ({len(comments)})\n")
    if not comments:
        out.append("_(none)_\n")
    for c in comments:
        cauthor = (c.get("author") or {}).get("login") or "?"
        when = c.get("createdAt") or ""
        out.append(f"### `@{cauthor}` · {when}\n")
        cbody = (c.get("body") or "").strip()
        out.append(cbody if cbody else "_(no body)_")
        out.append("")

    return "\n".join(out) + "\n"


# ─── File walking + content index ──────────────────────────────────────────

def list_files(root: Path, restrict_to: set[str] | None = None) -> list[str]:
    """Recursive file list relative to root; honours SKIP_DIRS.

    If `restrict_to` is given, only returns paths in that set.
    """
    out: list[str] = []
    for dirpath, dirnames, filenames in os.walk(root):
        dirnames[:] = [d for d in dirnames if d not in SKIP_DIRS]
        for f in filenames:
            if f == ".DS_Store":
                continue
            full = Path(dirpath) / f
            try:
                rel = full.relative_to(root)
            except ValueError:
                continue
            relstr = str(rel)
            if restrict_to is not None and relstr not in restrict_to:
                continue
            out.append(relstr)
    out.sort()
    return out


def build_md_index(root: Path, files: list[str]) -> dict[str, str]:
    """Read every .md file under root into memory for content search."""
    idx: dict[str, str] = {}
    for rel in files:
        if not rel.lower().endswith(MD_EXTS):
            continue
        full = root / rel
        try:
            if full.stat().st_size > SEARCH_INDEX_SIZE_LIMIT:
                continue
            idx[rel] = full.read_text(encoding="utf-8", errors="replace")
        except OSError:
            continue
    return idx


def search_index(index: dict[str, str], query: str) -> list[dict]:
    """Return ranked matches: [{path, snippets:[{line, text}], total}]. Case-insensitive."""
    q = query.strip().lower()
    if not q:
        return []
    results: list[dict] = []
    for path, content in index.items():
        lower = content.lower()
        if q not in lower:
            continue
        total = lower.count(q)
        snippets: list[dict] = []
        for i, line in enumerate(content.splitlines(), start=1):
            if q in line.lower():
                # Cap snippet length for the wire.
                snippet = line.strip()
                if len(snippet) > 240:
                    snippet = snippet[:240] + "…"
                snippets.append({"line": i, "text": snippet})
                if len(snippets) >= SEARCH_SNIPPETS_PER_FILE:
                    break
        results.append({"path": path, "snippets": snippets, "total": total})
    # Rank: higher total first, then path alphabetical.
    results.sort(key=lambda r: (-r["total"], r["path"]))
    return results[:SEARCH_MAX_RESULTS]


# ─── Spec resolution ───────────────────────────────────────────────────────

def resolve_spec(spec: str) -> dict:
    """
    Resolve a CLI/UI input string to a serveable target. Performs cloning /
    PR checkout as needed and returns:
        {target, restrict_to, github_context, pr_review_comments, root_label,
         owns_target}  # owns_target: True if we created a tempdir to clean up
    """
    pr = github_pr_spec(spec)
    if pr is not None:
        owner, repo, num = pr
        target, changed, gh_ctx, comments = fetch_pr(owner, repo, num)
        return {
            "target": target,
            "restrict_to": set(changed) | {"_PR.md"},
            "github_context": gh_ctx,
            "pr_review_comments": comments,
            "root_label": f"{owner}/{repo}#{num}",
            "owns_target": True,
        }
    gh_url = github_clone_url(spec)
    if gh_url is not None:
        target = clone_github(gh_url)
        # Extract owner/repo from the clone URL so the tree label looks like
        # "Meesho/containerize-model" rather than the tempdir's randomised name.
        m = re.match(r"^(?:https?://github\.com/|git@github\.com:)([\w.-]+)/([\w.-]+?)(?:\.git)?/?$", gh_url)
        label = f"{m.group(1)}/{m.group(2)}" if m else target.name
        return {
            "target": target,
            "restrict_to": None,
            "github_context": detect_repo_github_context(target),
            "pr_review_comments": {},
            "root_label": label,
            "owns_target": True,
        }
    target = Path(spec).expanduser()
    if not target.is_absolute():
        target = (Path.cwd() / target).resolve()
    if not target.exists():
        raise SystemExit(f"mdbrowse: not found: {target}")
    if not target.is_dir():
        raise SystemExit(f"mdbrowse: not a directory: {target}")
    return {
        "target": target,
        "restrict_to": None,
        "github_context": detect_repo_github_context(target),
        "pr_review_comments": {},
        "root_label": target.name,
        "owns_target": False,
    }


# ─── HTTP server ───────────────────────────────────────────────────────────

def serve_app(initial: dict | None, md_only: bool) -> None:
    """
    Serve the file-browser app. Starts even with no `initial` target — the
    user can paste a PR/repo/path URL into the toolbar to load one. Subsequent
    swaps via /__mdbrowse__/load reuse the same server.
    """
    port = free_port()
    state_lock = threading.Lock()
    state: dict = {
        "target": None,
        "restrict_to": None,
        "github_context": None,
        "pr_review_comments": {},
        "display_root": "(nothing loaded)",
        "files": [],
        "md_index": {},
        "owns_target": False,
    }

    def apply_resolved(resolved: dict) -> None:
        files = list_files(resolved["target"], restrict_to=resolved["restrict_to"])
        md_index = build_md_index(resolved["target"], files)
        with state_lock:
            old_target = state["target"]
            old_owned = state["owns_target"]
            state.update({
                "target": resolved["target"],
                "restrict_to": resolved["restrict_to"],
                "github_context": resolved["github_context"],
                "pr_review_comments": resolved["pr_review_comments"],
                "display_root": resolved["root_label"],
                "owns_target": resolved["owns_target"],
                "files": files,
                "md_index": md_index,
            })
        # Free the previous tempdir if we owned it.
        if old_owned and old_target and old_target != resolved["target"]:
            shutil.rmtree(old_target, ignore_errors=True)

    if initial:
        apply_resolved(initial)

    def refresh_state() -> dict:
        target = state["target"]
        if not target:
            return {"files": [], "md_index": {}}
        files = list_files(target, restrict_to=state["restrict_to"])
        md_index = build_md_index(target, files)
        with state_lock:
            state["files"] = files
            state["md_index"] = md_index
        return {"files": files, "md_index": md_index}

    class MdbrowseHandler(http.server.SimpleHTTPRequestHandler):
        # Quiet per-request stderr spam.
        def log_message(self, *args, **kwargs) -> None:
            pass

        def _send_bytes(self, body: bytes, ctype: str, status: int = 200) -> None:
            self.send_response(status)
            self.send_header("Content-Type", ctype)
            self.send_header("Content-Length", str(len(body)))
            self.send_header("Cache-Control", "no-store")
            self.end_headers()
            self.wfile.write(body)

        def _send_json(self, payload: dict, status: int = 200) -> None:
            self._send_bytes(json.dumps(payload).encode("utf-8"),
                             "application/json", status)

        def _read_json_body(self) -> dict | None:
            length = int(self.headers.get("Content-Length") or 0)
            try:
                return json.loads(self.rfile.read(length) or b"{}")
            except json.JSONDecodeError:
                return None

        def do_POST(self) -> None:
            split = urlsplit(self.path)
            if split.path == "/__mdbrowse__/load":
                self._handle_load()
                return
            if split.path == "/__mdbrowse__/post-comment":
                self._handle_post_comment()
                return
            self._send_json({"error": "not found"}, 404)

        def _handle_load(self) -> None:
            body = self._read_json_body()
            if body is None:
                self._send_json({"error": "invalid JSON"}, 400)
                return
            spec = (body.get("spec") or "").strip()
            if not spec:
                self._send_json({"error": "spec required"}, 400)
                return
            try:
                resolved = resolve_spec(spec)
            except SystemExit as e:
                self._send_json({"error": str(e)}, 400)
                return
            except Exception as e:
                self._send_json({"error": f"load failed: {e}"}, 500)
                return
            apply_resolved(resolved)
            print(f"mdbrowse: switched to  {resolved['root_label']}")
            self._send_json({"ok": True, "root": resolved["root_label"]})

        def _handle_post_comment(self) -> None:
            ghctx = state["github_context"]
            if not ghctx or not ghctx.get("prNumber"):
                self._send_json({"error": "post-comment is only available in PR mode"}, 400)
                return
            body = self._read_json_body()
            if body is None:
                self._send_json({"error": "invalid JSON"}, 400)
                return
            file_path = body.get("path")
            line_num = body.get("line")
            comment = body.get("body") or ""
            if not file_path or not isinstance(line_num, int) or not comment.strip():
                self._send_json({"error": "path, line (int), and body are required"}, 400)
                return
            args = [
                "gh", "api",
                f"repos/{ghctx['owner']}/{ghctx['repo']}/pulls/{ghctx['prNumber']}/comments",
                "-X", "POST",
                "-f", f"body={comment}",
                "-f", f"commit_id={ghctx['headRef']}",
                "-f", f"path={file_path}",
                "-F", f"line={line_num}",
                "-f", "side=RIGHT",
            ]
            try:
                result = subprocess.run(args, capture_output=True, text=True, timeout=30)
            except subprocess.SubprocessError as e:
                self._send_json({"error": f"gh api failed: {e}"}, 500)
                return
            if result.returncode != 0:
                self._send_json({"error": (result.stderr or "gh api failed").strip()}, 502)
                return
            try:
                payload = json.loads(result.stdout or "{}")
            except json.JSONDecodeError:
                self._send_json({"error": "could not parse gh api response"}, 502)
                return
            new_entry = {
                "line": payload.get("line") or payload.get("original_line") or line_num,
                "body": payload.get("body") or comment,
                "user": (payload.get("user") or {}).get("login") or "?",
                "createdAt": payload.get("created_at") or "",
                "htmlUrl": payload.get("html_url") or "",
            }
            with state_lock:
                state["pr_review_comments"].setdefault(file_path, []).append(new_entry)
                state["pr_review_comments"][file_path].sort(
                    key=lambda c: ((c.get("line") or 0), c.get("createdAt") or "")
                )
            self._send_json({"ok": True, "comment": new_entry})

        def do_GET(self) -> None:
            split = urlsplit(self.path)
            path = split.path
            if path == "/__mdbrowse__/tree.json":
                fresh = refresh_state()
                meta = {
                    "root": state["display_root"],
                    "files": fresh["files"],
                    "rootAbs": str(state["target"]) if state["target"] else None,
                    "github": state["github_context"],
                    "prReviewComments": state["pr_review_comments"],
                    "loaded": state["target"] is not None,
                }
                self._send_bytes(json.dumps(meta).encode("utf-8"), "application/json")
                return
            if path == "/__mdbrowse__/index.html":
                # Re-read on every request so HTML edits land without a restart.
                self._send_bytes(APP_HTML.read_bytes(), "text/html; charset=utf-8")
                return
            if path == "/__mdbrowse__/search":
                qs = parse_qs(split.query)
                q = (qs.get("q") or [""])[0]
                with state_lock:
                    idx = state["md_index"]
                body = json.dumps({"query": q, "results": search_index(idx, q)})
                self._send_bytes(body.encode("utf-8"), "application/json")
                return
            # /__mdbrowse__/<spec> — load shortcut. Lets the user paste a
            # github.com PR URL directly into the address bar by prefixing it
            # with http://127.0.0.1:<port>/__mdbrowse__/ and the server resolves
            # + 302s to the viewer.
            if path.startswith("/__mdbrowse__/"):
                spec_path = path[len("/__mdbrowse__/"):]
                if not spec_path:
                    self.send_response(302)
                    self.send_header("Location",
                                     "/__mdbrowse__/index.html?serve=1&mdOnly=1")
                    self.end_headers()
                    return
                spec = spec_path
                # Browsers collapse "https://" to "https:/" in the path. Restore.
                if spec.startswith("https:/") and not spec.startswith("https://"):
                    spec = "https://" + spec[len("https:/"):]
                elif spec.startswith("http:/") and not spec.startswith("http://"):
                    spec = "http://" + spec[len("http:/"):]
                if split.query:
                    spec += "?" + split.query
                try:
                    resolved = resolve_spec(spec)
                except SystemExit as e:
                    self._send_bytes(str(e).encode("utf-8"), "text/plain; charset=utf-8", 400)
                    return
                except Exception as e:
                    self._send_bytes(f"load failed: {e}".encode("utf-8"),
                                     "text/plain; charset=utf-8", 500)
                    return
                apply_resolved(resolved)
                print(f"mdbrowse: switched to  {resolved['root_label']}")
                self.send_response(302)
                self.send_header("Location",
                                 "/__mdbrowse__/index.html?serve=1&mdOnly=1")
                self.end_headers()
                return
            # File fetch — translate against the currently-loaded target.
            target = state["target"]
            if target is None:
                self.send_error(404, "no folder loaded")
                return
            self.directory = str(target)
            return super().do_GET()

    server = http.server.ThreadingHTTPServer(("127.0.0.1", port), MdbrowseHandler)
    flag = "0" if not md_only else "1"
    url = f"http://127.0.0.1:{port}/__mdbrowse__/index.html?serve=1&mdOnly={flag}"

    if state["target"]:
        print(f"mdbrowse: serving  {state['target']}")
        print(f"mdbrowse: indexed  {len(state['md_index'])} markdown file(s) for content search")
    else:
        print(f"mdbrowse: idle — paste a PR / repo / path in the app to load one")
    print(f"mdbrowse: app at   {url}")
    print(f"mdbrowse: Ctrl+C to stop")

    t = threading.Thread(target=server.serve_forever, daemon=True)
    t.start()
    open_chrome(url)
    try:
        t.join()
    except KeyboardInterrupt:
        print("\nmdbrowse: shutting down")
        server.shutdown()


# Backward-compat alias used by older callers.
def serve_folder(target: Path, md_only: bool, restrict_to: set[str] | None = None,
                 root_label: str | None = None,
                 github_context: dict | None = None,
                 pr_review_comments: dict[str, list[dict]] | None = None) -> None:
    initial = {
        "target": target,
        "restrict_to": restrict_to,
        "github_context": github_context,
        "pr_review_comments": pr_review_comments or {},
        "root_label": root_label or target.name,
        "owns_target": False,
    }
    serve_app(initial, md_only)


def main() -> int:
    args = parse_args()
    md_only = not args.all

    if args.update:
        return self_update()

    if not APP_HTML.exists():
        print(f"mdbrowse: app not found at {APP_HTML}", file=sys.stderr)
        return 2

    # Background notice if the install dir is behind origin.
    maybe_check_for_updates()

    # No-arg: start the server with no target loaded; the user can paste a
    # PR / repo / path in the app's toolbar to load one.
    if args.path is None:
        serve_app(None, md_only)
        return 0

    # Single local file: Chrome handles HTML/PDF/images natively. For .md /
    # .py / etc. Chrome just shows raw text; running the full server for one
    # file is over-kill, so we just open the file directly.
    direct = Path(args.path).expanduser()
    if direct.is_absolute() or direct.exists():
        if not direct.is_absolute():
            direct = (Path.cwd() / direct).resolve()
        if direct.is_file():
            open_chrome(f"file://{direct}")
            return 0

    # Otherwise resolve the spec (PR / repo / dir) and serve.
    initial = resolve_spec(args.path)
    serve_app(initial, md_only)
    return 0


if __name__ == "__main__":
    sys.exit(main())
