#!/usr/bin/env python3
"""
mdbrowse — open a file, folder, GitHub repo, or GitHub PR in the file-browser app.

Usage:
  mdbrowse                       open the app, no folder loaded
  mdbrowse PATH                  open file or folder (PATH may be relative)
  mdbrowse owner/repo            shallow-clone a GitHub repo and serve it
  mdbrowse https://github.com/owner/repo
  mdbrowse owner/repo#123        check out PR #123 and serve only its changed files
  mdbrowse https://github.com/owner/repo/pull/123
  mdbrowse PATH --all            show every file (default: only .md / .markdown / .mdx)
  mdbrowse PATH -a               shorthand for --all

Behaviour:
  * No PATH      — opens the app idle. The "Markdown only" toggle reflects the
                   --all flag (on by default).
  * PATH is file — opens the file directly in Chrome (Chrome handles HTML /
                   PDF / images natively; everything else is shown raw).
  * PATH is dir  — spins up a localhost HTTP server rooted at PATH, opens the
                   app pointed at it, and the app fetches files over HTTP.
                   Ctrl+C to stop the server.
  * GitHub spec  — `git clone --depth 1` into a temp dir, then serve as above.
                   Temp dir is removed on Ctrl+C.

Skip list (folders never indexed):
  .git  node_modules  __pycache__  .DS_Store  .next  dist  build  .venv  venv
"""
from __future__ import annotations
import argparse
import atexit
import functools
import http.server
import json
import os
import re
import shutil
import socket
import subprocess
import sys
import tempfile
import threading
from pathlib import Path
from urllib.parse import parse_qs, urlsplit

SCRIPT_DIR = Path(__file__).resolve().parent
APP_HTML = SCRIPT_DIR / "index.html"

SKIP_DIRS = {".git", "node_modules", "__pycache__", ".DS_Store",
             ".next", "dist", "build", ".venv", "venv"}

MD_EXTS = (".md", ".markdown", ".mdx")
SEARCH_INDEX_SIZE_LIMIT = 1 * 1024 * 1024  # 1 MB per file
SEARCH_MAX_RESULTS = 50
SEARCH_SNIPPETS_PER_FILE = 3


def parse_args() -> argparse.Namespace:
    ap = argparse.ArgumentParser(
        prog="mdbrowse",
        description="Open a file, folder, or GitHub repo in the file-browser app.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            "Examples:\n"
            "  mdbrowse                          # idle app, md-only on\n"
            "  mdbrowse vTax/containerize-executor\n"
            "  mdbrowse vTax -a                  # show all files, not just .md\n"
            "  mdbrowse vTax/README.md           # render a single file in Chrome\n"
            "  mdbrowse agarwal-manav/mdbrowse   # clone + serve a GitHub repo\n"
        ),
    )
    ap.add_argument("path", nargs="?", help="file, folder, or GitHub spec")
    ap.add_argument("-a", "--all", action="store_true",
                    help="show every file (default: markdown only)")
    return ap.parse_args()


def open_chrome(url: str) -> None:
    """Open a URL in Chrome; fall back to default browser if Chrome is absent."""
    chrome = "/Applications/Google Chrome.app"
    if Path(chrome).exists():
        subprocess.run(["open", "-a", "Google Chrome", url], check=False)
    else:
        subprocess.run(["open", url], check=False)


def free_port(start: int = 8765) -> int:
    """Find an unused port starting from `start`."""
    for p in range(start, start + 200):
        with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
            try:
                s.bind(("127.0.0.1", p))
                return p
            except OSError:
                continue
    raise RuntimeError("could not find a free port in 200 attempts")


# ─── GitHub repo support ───────────────────────────────────────────────────

# owner/repo — letters, digits, dots, dashes, underscores.
_GH_SHORT = re.compile(r"^[\w.-]+/[\w.-]+$")


def github_clone_url(spec: str) -> str | None:
    """Return a clonable URL if `spec` looks like a GitHub repo, else None."""
    if _GH_SHORT.match(spec):
        return f"https://github.com/{spec}.git"
    if spec.startswith("git@github.com:"):
        return spec
    if spec.startswith(("http://", "https://")):
        host = urlsplit(spec).netloc.lower()
        if host in ("github.com", "www.github.com"):
            return spec if spec.endswith(".git") else spec.rstrip("/") + ".git"
    return None


def clone_github(url: str) -> Path:
    """Shallow-clone `url` into a temp dir and register cleanup. Returns the dir."""
    tmp = Path(tempfile.mkdtemp(prefix="mdbrowse-"))
    atexit.register(lambda: shutil.rmtree(tmp, ignore_errors=True))
    print(f"mdbrowse: cloning {url}")
    try:
        subprocess.run(
            ["git", "clone", "--depth", "1", url, str(tmp)],
            check=True,
        )
    except subprocess.CalledProcessError as e:
        shutil.rmtree(tmp, ignore_errors=True)
        raise SystemExit(f"mdbrowse: git clone failed ({e.returncode})")
    return tmp


# ─── GitHub PR support ─────────────────────────────────────────────────────

# owner/repo#123
_GH_PR_SHORT = re.compile(r"^([\w.-]+)/([\w.-]+)#(\d+)$")
# https://github.com/owner/repo/pull/123 (trailing slash or /files etc. ignored)
_GH_PR_URL = re.compile(r"^https?://github\.com/([\w.-]+)/([\w.-]+)/pull/(\d+)(?:[/?#].*)?$")


def github_pr_spec(spec: str) -> tuple[str, str, int] | None:
    """Return (owner, repo, number) if `spec` is a GitHub PR reference, else None."""
    m = _GH_PR_SHORT.match(spec) or _GH_PR_URL.match(spec)
    if not m:
        return None
    return m.group(1), m.group(2), int(m.group(3))


def _ensure_gh() -> None:
    if shutil.which("gh") is None:
        raise SystemExit(
            "mdbrowse: PR mode needs the GitHub CLI. Install it: brew install gh"
        )


def fetch_pr(owner: str, repo: str, num: int) -> tuple[Path, list[str]]:
    """
    Clone owner/repo, check out PR #num via `gh`, and return:
        (tmpdir, changed_file_paths)
    The PR summary is written to `<tmpdir>/_PR.md`. Cleanup is registered with atexit.
    """
    _ensure_gh()
    pr_ref = f"{owner}/{repo}#{num}"

    print(f"mdbrowse: fetching metadata for {pr_ref}")
    fields = (
        "title,body,author,state,url,labels,baseRefName,headRefName,"
        "additions,deletions,createdAt,mergedAt,comments,reviews,files"
    )
    try:
        raw = subprocess.check_output(
            ["gh", "pr", "view", str(num), "--repo", f"{owner}/{repo}",
             "--json", fields],
            text=True,
        )
    except subprocess.CalledProcessError as e:
        raise SystemExit(f"mdbrowse: gh pr view failed ({e.returncode})")
    meta = json.loads(raw)

    tmp = Path(tempfile.mkdtemp(prefix="mdbrowse-pr-"))
    atexit.register(lambda: shutil.rmtree(tmp, ignore_errors=True))

    print(f"mdbrowse: cloning {owner}/{repo}")
    try:
        subprocess.run(
            ["git", "clone", "--quiet", f"https://github.com/{owner}/{repo}.git", str(tmp)],
            check=True,
        )
        print(f"mdbrowse: checking out PR #{num}")
        subprocess.run(
            ["gh", "pr", "checkout", str(num)],
            cwd=str(tmp), check=True,
        )
    except subprocess.CalledProcessError as e:
        shutil.rmtree(tmp, ignore_errors=True)
        raise SystemExit(f"mdbrowse: clone/checkout failed ({e.returncode})")

    # Files that still exist after checkout (excludes deleted files).
    changed: list[str] = []
    for f in meta.get("files", []) or []:
        path = f.get("path")
        if path and (tmp / path).exists():
            changed.append(path)

    # Synthesised summary at the root of the served tree.
    (tmp / "_PR.md").write_text(render_pr_markdown(meta, owner, repo, num), encoding="utf-8")

    return tmp, changed


def render_pr_markdown(meta: dict, owner: str, repo: str, num: int) -> str:
    """Render PR metadata, description, comments, and reviews as a single markdown doc."""
    title = meta.get("title") or "(no title)"
    state = meta.get("state") or "?"
    author = (meta.get("author") or {}).get("login") or "?"
    labels = ", ".join(l.get("name", "") for l in (meta.get("labels") or [])) or "—"
    base = meta.get("baseRefName") or "?"
    head = meta.get("headRefName") or "?"
    url = meta.get("url") or f"https://github.com/{owner}/{repo}/pull/{num}"
    adds = meta.get("additions", 0)
    dels = meta.get("deletions", 0)
    created = meta.get("createdAt") or ""
    merged = meta.get("mergedAt") or ""

    out: list[str] = []
    out.append(f"# PR #{num}: {title}\n")
    out.append(f"[{url}]({url})\n")
    out.append("")
    out.append("| | |")
    out.append("|---|---|")
    out.append(f"| Author | `@{author}` |")
    out.append(f"| State | **{state}** |")
    out.append(f"| Branch | `{head}` → `{base}` |")
    out.append(f"| Diff | +{adds} / −{dels} |")
    out.append(f"| Labels | {labels} |")
    if created:
        out.append(f"| Created | {created} |")
    if merged:
        out.append(f"| Merged | {merged} |")
    out.append("")

    body = (meta.get("body") or "").strip()
    out.append("## Description\n")
    out.append(body if body else "_(no description)_")
    out.append("")

    files = meta.get("files") or []
    out.append(f"## Changed files ({len(files)})\n")
    for f in files:
        path = f.get("path", "")
        a = f.get("additions", 0)
        d = f.get("deletions", 0)
        out.append(f"- `{path}` — +{a}/−{d}")
    out.append("")

    reviews = [r for r in (meta.get("reviews") or []) if (r.get("body") or "").strip() or r.get("state")]
    out.append(f"## Reviews ({len(reviews)})\n")
    if not reviews:
        out.append("_(none)_\n")
    for r in reviews:
        rauthor = (r.get("author") or {}).get("login") or "?"
        rstate = r.get("state") or ""
        when = r.get("submittedAt") or ""
        out.append(f"### `@{rauthor}` — **{rstate}** · {when}\n")
        rbody = (r.get("body") or "").strip()
        out.append(rbody if rbody else "_(no body)_")
        out.append("")

    comments = meta.get("comments") or []
    out.append(f"## Issue comments ({len(comments)})\n")
    if not comments:
        out.append("_(none)_\n")
    for c in comments:
        cauthor = (c.get("author") or {}).get("login") or "?"
        when = c.get("createdAt") or ""
        out.append(f"### `@{cauthor}` · {when}\n")
        cbody = (c.get("body") or "").strip()
        out.append(cbody if cbody else "_(no body)_")
        out.append("")

    return "\n".join(out) + "\n"


# ─── File walking + content index ──────────────────────────────────────────

def list_files(root: Path, restrict_to: set[str] | None = None) -> list[str]:
    """Recursive file list relative to root; honours SKIP_DIRS.

    If `restrict_to` is given, only returns paths in that set.
    """
    out: list[str] = []
    for dirpath, dirnames, filenames in os.walk(root):
        dirnames[:] = [d for d in dirnames if d not in SKIP_DIRS]
        for f in filenames:
            if f == ".DS_Store":
                continue
            full = Path(dirpath) / f
            try:
                rel = full.relative_to(root)
            except ValueError:
                continue
            relstr = str(rel)
            if restrict_to is not None and relstr not in restrict_to:
                continue
            out.append(relstr)
    out.sort()
    return out


def build_md_index(root: Path, files: list[str]) -> dict[str, str]:
    """Read every .md file under root into memory for content search."""
    idx: dict[str, str] = {}
    for rel in files:
        if not rel.lower().endswith(MD_EXTS):
            continue
        full = root / rel
        try:
            if full.stat().st_size > SEARCH_INDEX_SIZE_LIMIT:
                continue
            idx[rel] = full.read_text(encoding="utf-8", errors="replace")
        except OSError:
            continue
    return idx


def search_index(index: dict[str, str], query: str) -> list[dict]:
    """Return ranked matches: [{path, snippets:[{line, text}], total}]. Case-insensitive."""
    q = query.strip().lower()
    if not q:
        return []
    results: list[dict] = []
    for path, content in index.items():
        lower = content.lower()
        if q not in lower:
            continue
        total = lower.count(q)
        snippets: list[dict] = []
        for i, line in enumerate(content.splitlines(), start=1):
            if q in line.lower():
                # Cap snippet length for the wire.
                snippet = line.strip()
                if len(snippet) > 240:
                    snippet = snippet[:240] + "…"
                snippets.append({"line": i, "text": snippet})
                if len(snippets) >= SEARCH_SNIPPETS_PER_FILE:
                    break
        results.append({"path": path, "snippets": snippets, "total": total})
    # Rank: higher total first, then path alphabetical.
    results.sort(key=lambda r: (-r["total"], r["path"]))
    return results[:SEARCH_MAX_RESULTS]


# ─── HTTP server ───────────────────────────────────────────────────────────

def serve_folder(target: Path, md_only: bool, restrict_to: set[str] | None = None,
                 root_label: str | None = None) -> None:
    port = free_port()
    app_body = APP_HTML.read_bytes()
    display_root = root_label or target.name

    # Tree + md index are recomputed on demand so the Refresh button picks
    # up newly-added files without restarting the server.
    state_lock = threading.Lock()
    state: dict = {"files": [], "md_index": {}}

    def refresh_state() -> dict:
        files = list_files(target, restrict_to=restrict_to)
        md_index = build_md_index(target, files)
        with state_lock:
            state["files"] = files
            state["md_index"] = md_index
        return {"files": files, "md_index": md_index}

    refresh_state()

    class MdbrowseHandler(http.server.SimpleHTTPRequestHandler):
        # Quiet the per-request stderr spam.
        def log_message(self, *args, **kwargs) -> None:
            pass

        def _send_bytes(self, body: bytes, ctype: str) -> None:
            self.send_response(200)
            self.send_header("Content-Type", ctype)
            self.send_header("Content-Length", str(len(body)))
            self.send_header("Cache-Control", "no-store")
            self.end_headers()
            self.wfile.write(body)

        def do_GET(self) -> None:
            split = urlsplit(self.path)
            path = split.path
            if path == "/__mdbrowse__/tree.json":
                fresh = refresh_state()
                meta = {"root": display_root, "files": fresh["files"], "rootAbs": str(target)}
                self._send_bytes(json.dumps(meta).encode("utf-8"), "application/json")
                return
            if path == "/__mdbrowse__/index.html":
                self._send_bytes(app_body, "text/html; charset=utf-8")
                return
            if path == "/__mdbrowse__/search":
                qs = parse_qs(split.query)
                q = (qs.get("q") or [""])[0]
                with state_lock:
                    idx = state["md_index"]
                body = json.dumps({"query": q, "results": search_index(idx, q)})
                self._send_bytes(body.encode("utf-8"), "application/json")
                return
            return super().do_GET()

    handler = functools.partial(MdbrowseHandler, directory=str(target))
    server = http.server.ThreadingHTTPServer(("127.0.0.1", port), handler)

    flag = "0" if not md_only else "1"
    url = f"http://127.0.0.1:{port}/__mdbrowse__/index.html?serve=1&mdOnly={flag}"

    print(f"mdbrowse: serving  {target}")
    print(f"mdbrowse: app at   {url}")
    print(f"mdbrowse: indexed  {len(state['md_index'])} markdown file(s) for content search")
    print(f"mdbrowse: Ctrl+C to stop  (use the 🔄 button in the app to pick up new files)")

    t = threading.Thread(target=server.serve_forever, daemon=True)
    t.start()
    open_chrome(url)
    try:
        t.join()
    except KeyboardInterrupt:
        print("\nmdbrowse: shutting down")
        server.shutdown()


def main() -> int:
    args = parse_args()
    md_only = not args.all

    if not APP_HTML.exists():
        print(f"mdbrowse: app not found at {APP_HTML}", file=sys.stderr)
        return 2

    if args.path is None:
        flag = "0" if not md_only else "1"
        open_chrome(f"file://{APP_HTML}?mdOnly={flag}")
        return 0

    # GitHub PR? Check first — PR specs (owner/repo#N) would otherwise be
    # mis-detected as repos by github_clone_url.
    pr = github_pr_spec(args.path)
    if pr is not None:
        owner, repo, num = pr
        target, changed = fetch_pr(owner, repo, num)
        # Always include the synthesised summary in the tree.
        restrict = set(changed) | {"_PR.md"}
        label = f"{owner}/{repo}#{num}"
        serve_folder(target, md_only, restrict_to=restrict, root_label=label)
        return 0

    # GitHub repo? Clone first, then fall through to folder serving.
    gh_url = github_clone_url(args.path)
    if gh_url is not None:
        target = clone_github(gh_url)
        serve_folder(target, md_only)
        return 0

    target = Path(args.path).expanduser()
    if not target.is_absolute():
        target = (Path.cwd() / target).resolve()
    if not target.exists():
        print(f"mdbrowse: not found: {target}", file=sys.stderr)
        return 1

    if target.is_file():
        # Single file — Chrome handles HTML/PDF/images natively. For .md, .py,
        # etc. Chrome shows raw text; the app's renderers don't apply. Routing
        # a single file through the served-folder mode would be over-kill.
        open_chrome(f"file://{target}")
        return 0

    serve_folder(target, md_only)
    return 0


if __name__ == "__main__":
    sys.exit(main())
